{
  "dependencies": {
    "@patternfly-java/charts": "0.9.2",
    "@patternfly-java/core": "0.9.2",
    "@patternfly-java/finder": "0.9.2",
    "@patternfly/patternfly": "^6.5.2",
    "dompurify": "^3.4.11"
  },
  "devDependencies": {
    "@cyclonedx/cdxgen": "^12.7.0",
    "esbuild": "^0.28.1",
    "vite": "^8.1.0"
  },
  "name": "hal-op",
  "packageManager": "pnpm@11.9.0",
  "private": true,
  "scripts": {
    "build:feature-pack": "vite build --config vite.config.js --mode feature-pack",
    "build:standalone": "vite build --config vite.config.js --mode standalone",
    "build:test-suite": "vite build --config vite.config.js --mode test-suite",
    "sbom": "cdxgen -o target/npm-bom.cdx.json -t js --json-pretty --only patternfly --only dompurify",
    "watch": "vite --config vite.config.js"
  }
}
